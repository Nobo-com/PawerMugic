# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and shared with LF line endings
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jar binary
*.gif binary
*.keystore binary
